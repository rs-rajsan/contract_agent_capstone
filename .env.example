# General Configuration
ENVIRONMENT=development

# Neo4j connection
NEO4J_URI=your_neo4j_uri
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j
AURA_INSTANCEID=your_aura_instance_id
AURA_INSTANCENAME=your_aura_instance_name

# LLM API keys
OPENAI_API_KEY=
GOOGLE_API_KEY=your_google_api_key
GEMINI_API_KEY=your_google_api_key  # Optional: Fallback for GOOGLE_API_KEY
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=

# Frontend Configuration
# Frontend & Backend Communication
VITE_BACKEND_URL=http://localhost:8000
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Tracing and Telemetry
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces

# Model Configuration
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-1.5-pro
OPENAI_MODEL_DEFAULT=gpt-4o
ANTHROPIC_MODEL_DEFAULT=claude-3-5-sonnet-latest
MISTRAL_MODEL_DEFAULT=mistral-large-latest

# LLM Parameters
LLM_DEFAULT_TEMPERATURE=0.0

# Redis Cache (Optional for Capstone)
# Redis is not required for the current phase but can be enabled for production performance
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=false
CACHE_DEFAULT_TTL=3600

# Cache TTL by operation (seconds)
CACHE_TTL_DEVIATION=1800
CACHE_TTL_JURISDICTION=3600
CACHE_TTL_PRECEDENT=7200

# Performance Monitoring
MONITORING_ENABLED=true
ALERT_THRESHOLD_CUAD=5000
ALERT_THRESHOLD_DEVIATION=2000
ALERT_THRESHOLD_PRECEDENT=3000
ALERT_THRESHOLD_JURISDICTION=1000

# Parallel Processing
MAX_WORKERS_DEVIATION=3
MAX_WORKERS_PRECEDENT=5
MAX_WORKERS_BATCH=5

# Timeouts (seconds)
TIMEOUT_PATTERN_MATCHING=1.0
TIMEOUT_PRECEDENT_CLAUSE=5.0
TIMEOUT_BATCH_CONTRACT=30.0

# Batch Processing
MAX_BATCH_SIZE=50
BACKGROUND_BATCH_THRESHOLD=10
BATCH_SEMAPHORE_LIMIT=5

# Feature Flags
ENABLE_SEMANTIC_ANALYSIS=true
ENABLE_PARALLEL_PROCESSING=true
ENABLE_ADAPTIVE_LEARNING=true
ENABLE_PHASE_FALLBACK=true
