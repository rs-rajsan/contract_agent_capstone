### Frontend – RBAC Guards

#### [NEW] `frontend/src/hooks/usePermissions.ts`
```typescript
export function usePermissions() {
  const { user } = useAuth();
  return {
    can: (perm: Permission) => ROLE_PERMISSIONS[user.role].has(perm),
    isAdmin: user?.role === 'admin',
    isReviewer: user?.role === 'reviewer',
    isApprover: user?.role === 'approver',
  }
}
```

