#### [NEW] `frontend/src/services/apiClient.ts`
Centralised fetch wrapper — single responsibility, applied to ALL API calls (DRY):
```typescript
export async function apiRequest<T>(path: string, options?: RequestInit): Promise<T> {
  const token = tokenStore.get();           // reads from memory (not localStorage directly)
  const correlationId = crypto.randomUUID();
  const headers = {
    'Content-Type': 'application/json',
    'X-Correlation-ID': correlationId,
    ...(token ? { Authorization: `Bearer ${token}` } : {}),
    ...options?.headers,
  };
  const res = await fetch(`${BACKEND_URL}${path}`, { ...options, headers });
  if (res.status === 401) {
    authEventBus.emit('unauthorized');       // AuthContext listens → logout + redirect
  }
  if (!res.ok) throw new ApiError(res.status, await res.json());
  return res.json();
}
```

